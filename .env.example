# Supabase — get these from Project Settings → API in your Supabase dashboard
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# Anthropic — only used locally by scripts/ (never shipped to the browser).
# The receipt scanner calls Claude via the `scan-receipt` Supabase Edge
# Function, which reads ANTHROPIC_API_KEY from Supabase secrets (set with
# `supabase secrets set ANTHROPIC_API_KEY=sk-ant-…`), NOT from this file.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here
