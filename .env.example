# Supabase — get these from Project Settings → API in your Supabase dashboard
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# Anthropic — only used locally by scripts/ (never shipped to the browser).
# The receipt scanner calls Claude via the `scan-receipt` Supabase Edge
# Function, which reads ANTHROPIC_API_KEY from Supabase secrets (set with
# `supabase secrets set ANTHROPIC_API_KEY=sk-ant-…`), NOT from this file.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Web Push — the PUBLIC half of the VAPID key pair. Safe to ship in the
# browser bundle; the private half lives in Supabase secrets.
#
# One-time setup:
#   1. Generate the pair:
#        npx web-push generate-vapid-keys
#   2. Paste the public key here.
#   3. Store the private key as a Supabase secret:
#        supabase secrets set VAPID_PRIVATE_KEY=<private>
#        supabase secrets set VAPID_PUBLIC_KEY=<public>
#        supabase secrets set VAPID_SUBJECT=mailto:you@example.com
#   4. Deploy the send-push edge function:
#        supabase functions deploy send-push --no-verify-jwt
#   5. Set these two on the DB so the fanout trigger can reach the
#      edge function (Database → Functions → Settings → custom settings):
#        app.settings.supabase_url = https://<ref>.supabase.co
#        app.settings.supabase_service_key = <service_role_key>
REACT_APP_VAPID_PUBLIC_KEY=
